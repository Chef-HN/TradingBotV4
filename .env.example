# Application
APP_NAME=TradingBotV3
APP_ENV=local
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8090
APP_API_KEY=

# Database (separate from V2)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=tradingbotv3
DB_USER=tradingbot
DB_PASSWORD=tradingbot

# Redis (separate DB index from V2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_SECRET_FILE=
COINBASE_SANDBOX=false

# Strategy tuning params (symbols, grid_levels, spacing_bps, etc.) are stored
# in the DB exchange_strategies table — NOT here. Only wallet/operational params:
STRATEGY_TOTAL_WALLET_USD=200
STRATEGY_SESSION_CAPITAL_USD=100
STRATEGY_MAKER_ONLY=true

# Risk
RISK_MAX_OPEN_LEVELS_PER_SIDE=5
RISK_MAX_TOTAL_NOTIONAL=200
RISK_MAX_DAILY_REALIZED_LOSS=20
RISK_MAX_UNREALIZED_LOSS_PER_SYMBOL=15
RISK_STRESS_PAUSE_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
